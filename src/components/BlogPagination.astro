---
import { Icon } from "astro-icon/components";
import { url } from "@src/utils/path";

interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

// Build href for a given page number
// Page 1 → /blogs/   |   Page N → /blogs/N
function pageHref(page: number): string {
  return url(page === 1 ? "/blogs/" : `/blogs/${page}`);
}

const prevHref = currentPage > 1 ? pageHref(currentPage - 1) : null;
const nextHref = currentPage < totalPages ? pageHref(currentPage + 1) : null;

const pages = Array.from({ length: totalPages }, (_, i) => ({
  label: i + 1,
  href: pageHref(i + 1),
  isActive: i + 1 === currentPage,
}));
---

{totalPages > 1 && (
  <div class="mt-12 flex justify-center gap-2">
    <!-- Prev button -->
    {prevHref ? (
      <a
        href={prevHref}
        class="cyber-btn bg-transparent border border-cyber-blue text-cyber-blue hover:bg-cyber-blue/10 font-bold py-2 px-4 transition-all duration-300"
        aria-label="Previous page"
      >
        <Icon name="fa6-solid:chevron-left" />
      </a>
    ) : (
      <span
        class="cyber-btn bg-transparent border border-cyber-blue/30 text-cyber-blue/30 font-bold py-2 px-4 cursor-not-allowed"
        aria-disabled="true"
      >
        <Icon name="fa6-solid:chevron-left" />
      </span>
    )}

    <!-- Page numbers -->
    {pages.map((page) => (
      <a
        href={page.href}
        class={`cyber-btn font-bold py-2 px-4 transition-all duration-300 ${
          page.isActive
            ? "bg-cyber-blue text-cyber-dark"
            : "bg-transparent border border-cyber-blue text-cyber-blue hover:bg-cyber-blue/10"
        }`}
        aria-current={page.isActive ? "page" : undefined}
      >
        {page.label}
      </a>
    ))}

    <!-- Next button -->
    {nextHref ? (
      <a
        href={nextHref}
        class="cyber-btn bg-transparent border border-cyber-blue text-cyber-blue hover:bg-cyber-blue/10 font-bold py-2 px-4 transition-all duration-300"
        aria-label="Next page"
      >
        <Icon name="fa6-solid:chevron-right" />
      </a>
    ) : (
      <span
        class="cyber-btn bg-transparent border border-cyber-blue/30 text-cyber-blue/30 font-bold py-2 px-4 cursor-not-allowed"
        aria-disabled="true"
      >
        <Icon name="fa6-solid:chevron-right" />
      </span>
    )}
  </div>
)}
