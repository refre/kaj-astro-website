---
import { url } from "@src/utils/path";
import { Icon } from "astro-icon/components";
export interface TestimonialType {
  quote: string;
  author: string;
  position: string;
  image: string;
}

export interface PartnerType {
  image: string;
  alt: string;
}

const testimonialData: TestimonialType[] = [
  {
    quote:
      "Autonomous and solution-oriented, Kajoble developed a.o. an automated energy metering reading solution for about a million connected data points (IoT), good for millions of data entries a day, which was never done. I can only recommend Kajoble.",
    author: "Xavier L.",
    position: "IT manager, Ista ltd",
    image: "/img/male3.png",
  },
  {
    quote:
      "Thanks for your high level expertise and for being able to explain such complex cases with simplified explanation that would make them understandable by any rookie (like me). Thanks for this fruitful, productive, successful and, above all, nice and pleasant collaboration",
    author: "Gregory D.",
    position: "CEO, Golf Delta",
    image: "/img/male2.jpg",
  },
  {
    quote:
      "Nous avons travaillé ensemble avec Kajoble durant plusieurs années sur différentes mises en place opérationnelles. Ce que j’apprécie particulièrement chez Kajoble, c’est cet équilibre d’ouverture et de détermination, leur capacité d’écoute et leur sens de la responsabilité. La capacité de Kajoble à jongler avec plusieurs projets est unique et fait une énorme différence dans le niveau d'une équipe et de sa productivité. Kajoble a le gout du travail bien fait. leur fiabilité et leur intégrité sont de précieux atouts; en complément de son expérience professionnelle, la sensibilité qu’il a développé plus récemment font de lui un allié de choix.",
    author: "Steve C.",
    position: "Head of IT, UltraIT",
    image: "/img/male1.jpg",
  },
  {
    quote:
      "Kajoble m'a apporté de précieux conseils pour la mise en place d'automatisations complexes, tout cela rapidement et simplement. Je le recommande les yeux fermés",
    author: "Rose-Marie P.",
    position: "Project Manager, GE Healthcare",
    image: "/img/female3.jpg",
  },
];

const partnerData: PartnerType[] = [
  { image: "/img/logo1.png", alt: "Partner 1" },
  { image: "/img/logo2.png", alt: "Partner 2" },
  { image: "/img/logo3.png", alt: "Client 1" },
  { image: "/img/logo4.png", alt: "Client 2" },
  { image: "/img/logo5.png", alt: "Partner 3" },
  { image: "/img/logo6.png", alt: "Client 3" },
];
---

<section
  id="testimonials"
  class="bg-cyber-dark/60 py-24 relative overflow-hidden"
>
  <div
    class="absolute w-96 h-96 bg-cyber-blue/5 rounded-full blur-3xl -top-20 -left-20 animate-pulse-slow"
  ></div>
  <div
    class="absolute w-64 h-64 bg-cyber-blue/5 rounded-full blur-3xl bottom-10 right-10 animate-pulse-slow"
    style="animation-delay: 2s;"
  ></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="flex justify-center mb-16">
      <div class="relative">
        <h2 class="text-3xl md:text-4xl font-bold text-center">
          What Our{" "}
          <span class="text-cyber-blue text-shadow-glow">Clients Say</span>
        </h2>
        <div class="h-1 w-32 bg-cyber-blue mt-4 mx-auto rounded-full glow"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div class="relative">
        <div class="splide" id="testimonials-slider">
          <div class="splide__track">
            <ul class="splide__list px-6">
              {testimonialData.map((testimonial) => (
                <li class="splide__slide">
                  <div
                    class="border border-cyber-blue/20 bg-cyber-dark/70 backdrop-blur-sm rounded-xl p-8 h-full relative group hover:border-cyber-blue/50 transition-all duration-300"
                  >
                    <div
                      class="absolute inset-0 bg-cyber-blue/10 blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                    ></div>
                    <Icon
                      name="fa6-solid:quote-left" class="text-cyber-blue text-3xl mb-4"
                    />
                    <p class="text-gray-300 mb-6">{testimonial.quote}</p>
                    <div class="flex items-center">
                      <div
                        class="w-12 h-12 rounded-full bg-cyber-blue/20 border border-cyber-blue flex items-center justify-center glow"
                      >
                        <img
                          src={url(testimonial.image)}
                          alt={testimonial.author}
                          class="w-full h-full rounded-full object-cover"
                        />
                      </div>
                      <div class="ml-4">
                        <h4 class="text-cyber-blue font-bold">
                          {testimonial.author}
                        </h4>
                        <p class="text-gray-400 text-sm">
                          {testimonial.position}
                        </p>
                      </div>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="grid grid-cols-2 gap-6">
          {partnerData.map((partner) => (
            <div
              class="border border-cyber-blue/20 bg-cyber-dark/70 backdrop-blur-sm rounded-xl p-4 flex items-center justify-center group hover:border-cyber-blue/50 transition-all duration-300"
            >
              <div
                class="absolute inset-0 bg-cyber-blue/10 blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              ></div>
              <img
                src={url(partner.image)}
                alt={partner.alt}
                class="h-12 opacity-70 group-hover:opacity-100 transition-opacity duration-300"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Include Splide.js
  import Splide from "@splidejs/splide";

  document.addEventListener("DOMContentLoaded", function () {
    new Splide("#testimonials-slider", {
      type: "loop",
      perPage: 1,
      autoplay: true,
      interval: 5000,
      pauseOnHover: true,
      arrows: false,
      pagination: true,
      speed: 800,
      easing: "cubic-bezier(0.4, 0, 0.2, 1)",
    }).mount();
  });
</script>